{
  "name": "aireplay",
  "version": "0.2.1",
  "type": "module",
  "description": "Local web app for browsing, searching, and editing AI conversation history and memory files",
  "author": "Brenden Chu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brendenchu/aireplay.git"
  },
  "homepage": "https://github.com/brendenchu/aireplay#readme",
  "bugs": {
    "url": "https://github.com/brendenchu/aireplay/issues"
  },
  "keywords": [
    "ai",
    "llm",
    "claude",
    "copilot",
    "gemini",
    "codex",
    "conversations",
    "memory",
    "local",
    "browser"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "aireplay": "./bin/aireplay.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && node build-server.mjs",
    "preview": "vite preview",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "check": "bun run lint && bun run typecheck",
    "typecheck": "vue-tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.0",
    "hono": "^4.12.14",
    "lucide-vue-next": "^1.0.0",
    "marked": "^18.0.0",
    "minisearch": "^7.2.0",
    "reka-ui": "^2.9.6",
    "shadcn-vue": "^2.6.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@tailwindcss/vite": "^4.2.2",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "vue-tsc": "^3.2.6"
  }
}
