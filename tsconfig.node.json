{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist/server",
    "paths": {
      "@server/*": ["./server/*"]
    }
  },
  "include": ["server/**/*.ts", "src/types/**/*.ts", "vite.config.ts"]
}
